# mind-builder-v0 — environment
#
# NEXT_PUBLIC_* vars are inlined at build time by Next.js — restart `next dev`
# AND hard-reload the browser tab after changing them.

# OIDC issuer. Defaults to the shared production pod so a single WebID flows
# across all sibling prototypes (SSO). For local single-stack dev point this
# at the mind-codespaces bridge's CSS so the WebID matches the bridge owner.
NEXT_PUBLIC_SOLID_ISSUER=http://localhost:3011/

# The mind-codespaces bridge that does the actual building.
NEXT_PUBLIC_CODESPACES_BRIDGE_URL=http://localhost:3010

# The pod base the signed-in WebID lives under. In single-stack dev this is
# the bridge's CSS (:3011); if you run mind-builder's own CSS it's :3071.
NEXT_PUBLIC_POD_BASE_URL=http://localhost:3011/

# How the builder server authorizes against the bridge:
#   dev       — send X-Mind-Dev-WebId (bridge must be non-production)
#   delegated — hold a bridge session cookie per WebID (not yet implemented)
BUILDER_BRIDGE_MODE=dev

# Local sqlite cache of project/build status (server-only, gitignored).
INDEXER_DATA_DIR=./.builder-data
